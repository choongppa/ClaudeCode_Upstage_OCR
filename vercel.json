{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/main.py" },
    { "src": "/(.*\\.(js|css|ico|svg|png|jpg|jpeg|gif|woff2?)$)", "dest": "frontend/dist/$1" },
    { "src": "/(.*)", "dest": "frontend/dist/index.html" }
  ]
}
